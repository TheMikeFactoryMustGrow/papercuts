#!/usr/bin/env python3
"""papercut — log agent friction (platform-agnostic, collision-safe).

Stores data under **.agent-papercuts/** by default so we never claim a product
file named PAPERCUTS.md or a game package using .papercuts/.

Open list: delete-on-fix via `papercut resolve`.
Shadow ledger: append-only history.jsonl for papercuts-kaizen.

Usage:
  papercut "message"
  papercut log|list|resolve|history|path|init|status|enable|install
"""

from __future__ import annotations

import argparse
import getpass
import json
import os
import re
import shutil
import sys
from collections import Counter
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path

# --- Ownership / namespace (collision avoidance) --------------------------------

OWNED_MARKER = "<!-- agent-papercuts:v1 -->"
DATA_DIR = ".agent-papercuts"
OPEN_NAME = "open.md"
HISTORY_NAME = "history.jsonl"

# Legacy locations still *read* if they carry our ownership marker
LEGACY_OPEN = "PAPERCUTS.md"
LEGACY_DIR = ".papercuts"

MARKER_BEGIN = "<!-- agent-papercuts:begin -->"
MARKER_END = "<!-- agent-papercuts:end -->"
# Accept first-edition markers so re-enable does not duplicate
LEGACY_MARKER_BEGIN = "<!-- papercuts:begin -->"
LEGACY_MARKER_END = "<!-- papercuts:end -->"

HEADER = f"""# Agent papercuts (open list)

{OWNED_MARKER}

This file is **agent tooling** (coding-agent friction), not product content.
If you are building a game/app about papercuts, your product files live elsewhere;
this tool only writes under `.agent-papercuts/` unless a legacy owned log exists.

Log:   `papercut "what you were doing → what got in the way"`
Clear: `papercut resolve --stamp <ts> -n "what you fixed"`
Sand:  skill **papercuts** · Long cycle: **papercuts-kaizen**

---

"""

AGENTS_SNIPPET = f"""{MARKER_BEGIN}
## Log agent papercuts

When you hit **small friction** while working — a tool call that missed and had
to be retried, a confusing or undocumented setup step, a flaky command, a stale
cache, a misleading error, a non-obvious gotcha — log it via:

```bash
papercut -m <model> "one or two sentences: what you were doing → what got in the way"
```

Data lives under **`.agent-papercuts/`** (not a root `PAPERCUTS.md`) so it does
not collide with product files. Do this **proactively, in the moment**.

Sand: skill **papercuts** ("fix the papercuts"). Clear with `papercut resolve`
(not hand-delete). Long cycle: **papercuts-kaizen**.
{MARKER_END}
"""

ENTRY_RE = re.compile(
    r"^(\d{4}-\d{2}-\d{2}T[^\s]+)\s+-\s+(\S+)\s+-\s+(\S+)\s*$",
    re.MULTILINE,
)

SUBCOMMANDS = {
    "log",
    "list",
    "path",
    "init",
    "install",
    "enable",
    "status",
    "resolve",
    "history",
}


def package_root() -> Path:
    here = Path(__file__).resolve().parent
    if (here.parent / "SKILL.md").exists() or (here.parent / "skills" / "papercuts").exists():
        return here.parent
    if here.parent.name == "papercuts" and (here.parent / "SKILL.md").exists():
        return here.parent
    return here.parent


def find_repo_root(start: Path) -> Path:
    start = start.resolve()
    for candidate in [start, *start.parents]:
        if (candidate / ".git").exists():
            return candidate
    return start


def repo_root(start: Path | None = None) -> Path:
    return find_repo_root(start or Path.cwd())


def is_owned_open_file(path: Path) -> bool:
    """True only if this file is ours — never treat foreign PAPERCUTS.md as owned."""
    if not path.exists() or not path.is_file():
        return False
    try:
        head = path.read_text(encoding="utf-8", errors="replace")[:8000]
    except OSError:
        return False
    if OWNED_MARKER in head:
        return True
    # Legacy open logs we wrote before the marker existed
    low = head.lower()
    if "# papercuts" in low and "sanding list" in low and (
        "papercut resolve" in low or "skill **papercuts**" in low or "skill: **papercuts**" in low
    ):
        return True
    return False


def is_owned_history_dir(path: Path) -> bool:
    """History dir is ours if it only contains our history file or is under data dir."""
    if not path.exists() or not path.is_dir():
        return False
    # Canonical data dir is always ours by name
    if path.name == DATA_DIR:
        return True
    # Legacy .papercuts — only claim if history.jsonl looks like our events
    hist = path / HISTORY_NAME
    if not hist.exists():
        return False
    try:
        sample = hist.read_text(encoding="utf-8", errors="replace")[:2000]
    except OSError:
        return False
    return '"event": "logged"' in sample or '"event":"logged"' in sample or sample.strip() == ""


@dataclass
class Store:
    root: Path
    open_path: Path
    history_path: Path
    warnings: list[str]


def resolve_store(root: Path) -> Store:
    """Pick open + history paths with collision avoidance.

    Priority:
      1. Canonical `.agent-papercuts/` if present or no legacy owned log
      2. Legacy `PAPERCUTS.md` / `.papercuts/` only if ownership markers match
      3. Never write to foreign root files
    """
    warnings: list[str] = []
    canonical_dir = root / DATA_DIR
    canonical_open = canonical_dir / OPEN_NAME
    canonical_hist = canonical_dir / HISTORY_NAME

    legacy_open = root / LEGACY_OPEN
    legacy_hist = root / LEGACY_DIR / HISTORY_NAME

    # Env override (advanced)
    env_open = os.environ.get("PAPERCUT_OPEN_PATH", "").strip()
    env_hist = os.environ.get("PAPERCUT_HISTORY_PATH", "").strip()
    if env_open:
        op = Path(env_open)
        if not op.is_absolute():
            op = root / op
        hp = Path(env_hist) if env_hist else op.parent / HISTORY_NAME
        if not hp.is_absolute():
            hp = root / hp
        return Store(root, op, hp, warnings)

    # Foreign root PAPERCUTS.md — never claim it
    if legacy_open.exists() and not is_owned_open_file(legacy_open):
        warnings.append(
            f"foreign_file={legacy_open} (exists without {OWNED_MARKER}; left untouched)"
        )

    # Prefer canonical if it exists
    if canonical_open.exists():
        if not is_owned_open_file(canonical_open) and canonical_open.stat().st_size > 0:
            warnings.append(
                f"collision={canonical_open} exists but is not an owned agent-papercuts file"
            )
            # Fall through carefully — refuse by using a sibling name
            alt = canonical_dir / "agent-open.md"
            warnings.append(f"using_alternate={alt}")
            return Store(root, alt, canonical_hist, warnings)
        return Store(root, canonical_open, canonical_hist, warnings)

    # Legacy owned open log
    if legacy_open.exists() and is_owned_open_file(legacy_open):
        hist = legacy_hist if legacy_hist.exists() else canonical_hist
        if legacy_hist.exists():
            warnings.append(f"legacy_history={legacy_hist}")
        warnings.append(f"legacy_open={legacy_open} (owned; consider migrating to {canonical_open})")
        return Store(root, legacy_open, hist, warnings)

    # Default: canonical (create on write)
    return Store(root, canonical_open, canonical_hist, warnings)


def store_for(start: Path | None = None) -> Store:
    return resolve_store(repo_root(start))


def ensure_owned_open(path: Path) -> None:
    """Create open log with ownership marker, or refuse foreign files."""
    if path.exists():
        if path.stat().st_size == 0:
            path.write_text(HEADER, encoding="utf-8")
            return
        if not is_owned_open_file(path):
            raise SystemExit(
                f"error: refusing to write {path} — file exists and is not an "
                f"agent-papercuts log (missing {OWNED_MARKER}). "
                f"Your product file is safe. Use a different path or remove the conflict."
            )
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(HEADER, encoding="utf-8")


def default_model() -> str:
    for key in (
        "PAPERCUT_MODEL",
        "AGENT_MODEL",
        "GROK_MODEL",
        "CLAUDE_MODEL",
        "ANTHROPIC_MODEL",
    ):
        val = os.environ.get(key, "").strip()
        if val:
            return val
    return "unknown"


def default_author() -> str:
    for key in ("PAPERCUT_AUTHOR", "GIT_AUTHOR_NAME", "USER"):
        val = os.environ.get(key, "").strip()
        if val:
            return val.replace(" ", "-").lower() if key == "GIT_AUTHOR_NAME" else val
    try:
        return getpass.getuser()
    except Exception:
        return "agent"


def utc_now_stamp() -> str:
    now = datetime.now(timezone.utc)
    return now.strftime("%Y-%m-%dT%H:%M:%S.") + f"{now.microsecond // 1000:03d}Z"


def append_history(hist_path: Path, root: Path, event: dict) -> Path:
    hist_path.parent.mkdir(parents=True, exist_ok=True)
    event = dict(event)
    event.setdefault("ts", utc_now_stamp())
    event.setdefault("repo_root", str(root))
    with hist_path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, ensure_ascii=False) + "\n")
    return hist_path


def read_history(hist_path: Path) -> list[dict]:
    if not hist_path.exists():
        return []
    events: list[dict] = []
    for line in hist_path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            events.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return events


def parse_entries(text: str) -> list[dict]:
    matches = list(ENTRY_RE.finditer(text))
    if not matches:
        return []
    entries: list[dict] = []
    for i, m in enumerate(matches):
        start = m.start()
        end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
        block = text[start:end].strip()
        lines = block.splitlines()
        body = "\n".join(lines[1:]).strip()
        entries.append(
            {
                "stamp": m.group(1),
                "model": m.group(2),
                "author": m.group(3),
                "body": body,
            }
        )
    return entries


def split_header_and_body(text: str) -> tuple[str, str]:
    m = ENTRY_RE.search(text)
    if not m:
        return text if text.strip() else HEADER, ""
    return text[: m.start()], text[m.start() :]


def rewrite_log_without(path: Path, remove_stamps: set[str]) -> list[dict]:
    text = path.read_text(encoding="utf-8") if path.exists() else HEADER
    if path.exists() and not is_owned_open_file(path):
        raise SystemExit(f"error: refusing to modify foreign file {path}")
    entries = parse_entries(text)
    removed = [e for e in entries if e["stamp"] in remove_stamps]
    keep = [e for e in entries if e["stamp"] not in remove_stamps]
    header, _ = split_header_and_body(text)
    if not header.strip():
        header = HEADER
    if OWNED_MARKER not in header:
        header = HEADER
    parts = [header.rstrip() + "\n\n"]
    for e in keep:
        parts.append(f"{e['stamp']} - {e['model']} - {e['author']}\n\n{e['body']}\n\n")
    path.write_text("".join(parts), encoding="utf-8")
    return removed


def emit_warnings(store: Store) -> None:
    for w in store.warnings:
        print(f"warning: {w}", file=sys.stderr)


def cmd_init(args: argparse.Namespace) -> int:
    store = store_for(Path(args.cwd) if args.cwd else None)
    emit_warnings(store)
    path = store.open_path
    if path.exists() and path.stat().st_size > 0 and not args.force:
        if is_owned_open_file(path):
            print(f"already exists: {path}", file=sys.stderr)
            return 0
        print(
            f"error: {path} exists and is not owned; refusing to overwrite",
            file=sys.stderr,
        )
        return 1
    if args.force and path.exists() and not is_owned_open_file(path):
        print(
            f"error: refusing --force on foreign file {path}",
            file=sys.stderr,
        )
        return 1
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(HEADER, encoding="utf-8")
    print(path)
    return 0


def cmd_path(args: argparse.Namespace) -> int:
    store = store_for(Path(args.cwd) if args.cwd else None)
    emit_warnings(store)
    print(store.open_path)
    return 0


def cmd_log(args: argparse.Namespace) -> int:
    message = " ".join(args.message).strip()
    if not message:
        print("error: empty message", file=sys.stderr)
        return 2
    message = re.sub(r"\s+", " ", message).strip()
    model = (args.model or default_model()).strip()
    author = (args.author or default_author()).strip()
    stamp = utc_now_stamp()
    store = store_for(Path(args.cwd) if args.cwd else None)
    emit_warnings(store)
    try:
        ensure_owned_open(store.open_path)
    except SystemExit as e:
        print(e, file=sys.stderr)
        return 1
    entry = f"{stamp} - {model} - {author}\n\n{message}\n\n"
    with store.open_path.open("a", encoding="utf-8") as f:
        f.write(entry)
    hist = append_history(
        store.history_path,
        store.root,
        {
            "event": "logged",
            "entry_stamp": stamp,
            "model": model,
            "author": author,
            "body": message,
        },
    )
    print(f"logged → {store.open_path}")
    print(f"  history → {hist}")
    print(f"  {stamp} - {model} - {author}")
    print(f"  {message}")
    return 0


def cmd_list(args: argparse.Namespace) -> int:
    store = store_for(Path(args.cwd) if args.cwd else None)
    emit_warnings(store)
    path = store.open_path
    if not path.exists():
        print(f"(no open log at {path})", file=sys.stderr)
        return 1
    if not is_owned_open_file(path):
        print(
            f"error: {path} is not an agent-papercuts log; refusing to list",
            file=sys.stderr,
        )
        return 1
    entries = parse_entries(path.read_text(encoding="utf-8"))
    if not entries:
        print(f"(empty log: {path})")
        return 0
    shown = list(reversed(entries))
    if args.n is not None:
        shown = shown[: args.n]
    print(f"{path}  ({len(entries)} total, showing {len(shown)})\n")
    for i, e in enumerate(shown, 1):
        print(f"{i}. {e['stamp']}  [{e['model']}]  {e['author']}")
        print(f"   {e['body']}")
        print()
    return 0


def cmd_resolve(args: argparse.Namespace) -> int:
    store = store_for(Path(args.cwd) if args.cwd else None)
    emit_warnings(store)
    path = store.open_path
    if not path.exists():
        print(f"error: no {path}", file=sys.stderr)
        return 1
    if not is_owned_open_file(path):
        print(f"error: refusing to resolve foreign file {path}", file=sys.stderr)
        return 1

    text = path.read_text(encoding="utf-8")
    entries = parse_entries(text)
    if not entries:
        print("(empty log — nothing to resolve)", file=sys.stderr)
        return 1

    note = (args.note or "").strip()
    if not note:
        print("error: -n/--note is required (one-line what you fixed)", file=sys.stderr)
        return 2

    selected: list[dict] = []
    stamps = list(args.stamp or [])
    contains = args.contains
    indices = list(args.index or [])

    if stamps:
        stamp_set = set(stamps)
        selected = [e for e in entries if e["stamp"] in stamp_set]
        missing = stamp_set - {e["stamp"] for e in selected}
        if missing:
            print(f"error: stamp(s) not in open log: {sorted(missing)}", file=sys.stderr)
            return 1
    elif contains:
        needle = contains.lower()
        selected = [e for e in entries if needle in e["body"].lower()]
        if not selected:
            print(f"error: no open entries matching --contains {contains!r}", file=sys.stderr)
            return 1
    elif indices:
        ordered = list(reversed(entries))
        for idx in indices:
            if idx < 1 or idx > len(ordered):
                print(f"error: index {idx} out of range 1..{len(ordered)}", file=sys.stderr)
                return 1
            selected.append(ordered[idx - 1])
        seen: set[str] = set()
        uniq = []
        for e in selected:
            if e["stamp"] not in seen:
                seen.add(e["stamp"])
                uniq.append(e)
        selected = uniq
    else:
        print(
            "error: select entries with --stamp, --contains, or --index",
            file=sys.stderr,
        )
        return 2

    remove = {e["stamp"] for e in selected}
    removed = rewrite_log_without(path, remove)
    for e in removed:
        append_history(
            store.history_path,
            store.root,
            {
                "event": "resolved",
                "entry_stamp": e["stamp"],
                "model": e["model"],
                "author": e["author"],
                "body": e["body"],
                "note": note,
                "resolved_by": default_author(),
            },
        )

    print(f"resolved {len(removed)} entr{'y' if len(removed) == 1 else 'ies'} → {path}")
    print(f"  history → {store.history_path}")
    print(f"  note: {note}")
    for e in removed:
        print(f"  - {e['stamp']}: {e['body'][:80]}{'…' if len(e['body']) > 80 else ''}")
    return 0


def cmd_history(args: argparse.Namespace) -> int:
    store = store_for(Path(args.cwd) if args.cwd else None)
    emit_warnings(store)
    events = read_history(store.history_path)
    path = store.history_path

    if args.stats:
        if not events:
            print(f"(no history at {path})")
            return 0
        by_event = Counter(e.get("event", "?") for e in events)
        print(f"{path}")
        print(f"total_events={len(events)}")
        for k, v in sorted(by_event.items()):
            print(f"  {k}={v}")
        logged_bodies = [
            e.get("body", "").strip().lower()
            for e in events
            if e.get("event") == "logged" and e.get("body")
        ]
        resolved_bodies = [
            e.get("body", "").strip().lower()
            for e in events
            if e.get("event") == "resolved" and e.get("body")
        ]
        body_log_counts = Counter(logged_bodies)
        multi = [(b, c) for b, c in body_log_counts.items() if c >= 2]
        multi.sort(key=lambda x: -x[1])
        print(f"unique_logged_bodies={len(body_log_counts)}")
        print(f"bodies_logged_gte_2={len(multi)}")
        print(f"resolved_count={len(resolved_bodies)}")
        if multi:
            print("\ntop repeated bodies (logged count):")
            for b, c in multi[:10]:
                preview = b[:90] + ("…" if len(b) > 90 else "")
                print(f"  {c}x  {preview}")
        return 0

    if not events:
        print(f"(no history at {path})")
        return 0

    filtered = events
    if args.event:
        filtered = [e for e in events if e.get("event") == args.event]
    shown = list(reversed(filtered))
    if args.n is not None:
        shown = shown[: args.n]

    print(f"{path}  ({len(filtered)} matching, showing {len(shown)})\n")
    for e in shown:
        ev = e.get("event", "?")
        stamp = e.get("entry_stamp") or e.get("ts", "")
        body = e.get("body", "")
        note = e.get("note", "")
        print(f"{ev:8}  {stamp}  [{e.get('model', '?')}]")
        if body:
            print(f"         {body}")
        if note:
            print(f"         fix: {note}")
        print()
    return 0


def skill_dirs_to_install(args: argparse.Namespace) -> list[Path]:
    home = Path.home()
    if args.claude or args.grok or args.agents:
        bases = []
        if args.claude:
            bases.append(home / ".claude" / "skills")
        if args.grok:
            bases.append(home / ".grok" / "skills")
        if args.agents:
            bases.append(home / ".agents" / "skills")
        return bases
    return [home / ".claude" / "skills", home / ".grok" / "skills"]


def _safe_symlink(link: Path, target: Path) -> str:
    """Create symlink; do not clobber an unrelated existing binary."""
    target = target.resolve()
    if link.exists() or link.is_symlink():
        if link.is_symlink():
            try:
                if link.resolve() == target:
                    return f"unchanged {link}"
            except OSError:
                pass
            # Our previous install or broken link — replace
            if "papercut" in str(link.resolve()) if link.exists() else True:
                try:
                    cur = os.readlink(link)
                    if "papercuts" in cur or cur.endswith("papercut"):
                        link.unlink()
                    else:
                        return f"skipped {link} (points elsewhere: {cur})"
                except OSError:
                    link.unlink()
            else:
                return f"skipped {link} (exists, not our symlink)"
        else:
            return f"skipped {link} (real file exists — not overwriting)"
    link.symlink_to(target)
    return f"installed CLI → {link} -> {target}"


def cmd_install(args: argparse.Namespace) -> int:
    root = package_root()
    scripts_src = root / "scripts" / "papercut"
    if not scripts_src.exists():
        scripts_src = Path(__file__).resolve()

    skills_to_install: list[tuple[str, Path]] = []
    main = root / "skills" / "papercuts" / "SKILL.md"
    if not main.exists():
        main = root / "SKILL.md"
    if main.exists():
        skills_to_install.append(("papercuts", main))
    kaizen = root / "skills" / "papercuts-kaizen" / "SKILL.md"
    if kaizen.exists():
        skills_to_install.append(("papercuts-kaizen", kaizen))

    if not skills_to_install:
        print("error: no SKILL.md found to install", file=sys.stderr)
        return 1

    for base in skill_dirs_to_install(args):
        for name, skill_md in skills_to_install:
            dest = base / name
            if dest.exists() or dest.is_symlink():
                if dest.is_symlink():
                    dest.unlink()
                elif dest.is_dir():
                    shutil.rmtree(dest)
            dest.mkdir(parents=True, exist_ok=True)
            shutil.copy2(skill_md, dest / "SKILL.md")
            (dest / "scripts").mkdir(exist_ok=True)
            shutil.copy2(scripts_src, dest / "scripts" / "papercut")
            os.chmod(dest / "scripts" / "papercut", 0o755)
            print(f"installed skill → {dest}")

    local_bin = Path.home() / ".local" / "bin"
    local_bin.mkdir(parents=True, exist_ok=True)
    os.chmod(scripts_src, 0o755)
    # Prefer namespaced binary; also offer papercut if safe
    print(_safe_symlink(local_bin / "agent-papercut", scripts_src.resolve()))
    print(_safe_symlink(local_bin / "papercut", scripts_src.resolve()))
    if str(local_bin) not in os.environ.get("PATH", ""):
        print(f"note: add {local_bin} to PATH", file=sys.stderr)
    print("done. In any project: papercut enable   (or agent-papercut enable)")
    print("data dir: .agent-papercuts/  (never overwrites foreign PAPERCUTS.md)")
    return 0


def _snippet_markers_present(text: str) -> bool:
    for begin, end in (
        (MARKER_BEGIN, MARKER_END),
        (LEGACY_MARKER_BEGIN, LEGACY_MARKER_END),
    ):
        if re.search(rf"^{re.escape(begin)}\s*$", text, re.M) and re.search(
            rf"^{re.escape(end)}\s*$", text, re.M
        ):
            return True
    return False


def cmd_enable(args: argparse.Namespace) -> int:
    root = repo_root(Path(args.cwd) if args.cwd else None)
    store = resolve_store(root)
    emit_warnings(store)

    agents = root / "AGENTS.md"
    target = agents
    if not agents.exists() and (root / "CLAUDE.md").exists() and args.prefer_claude:
        target = root / "CLAUDE.md"

    snippet = AGENTS_SNIPPET
    tpl = package_root() / "templates" / "AGENTS.snippet.md"
    if tpl.exists():
        snippet = tpl.read_text(encoding="utf-8")
        if MARKER_BEGIN not in snippet and LEGACY_MARKER_BEGIN not in snippet:
            snippet = f"{MARKER_BEGIN}\n{snippet.rstrip()}\n{MARKER_END}\n"

    if target.exists():
        text = target.read_text(encoding="utf-8")
        if _snippet_markers_present(text) and not args.force:
            print(f"already enabled in {target} (use --force to replace block)")
        else:
            if _snippet_markers_present(text):
                for begin, end in (
                    (MARKER_BEGIN, MARKER_END),
                    (LEGACY_MARKER_BEGIN, LEGACY_MARKER_END),
                ):
                    if begin in text and end in text:
                        text = re.sub(
                            re.escape(begin) + r".*?" + re.escape(end),
                            snippet.strip(),
                            text,
                            count=1,
                            flags=re.DOTALL,
                        )
                        break
            else:
                text = text.rstrip() + "\n\n" + snippet
            target.write_text(text if text.endswith("\n") else text + "\n", encoding="utf-8")
            print(f"updated {target}")
    else:
        target.write_text(
            f"# AGENTS.md\n\nProject instructions for coding agents.\n\n{snippet}",
            encoding="utf-8",
        )
        print(f"created {target}")

    # Always enable into canonical namespace unless already on owned legacy
    open_path = store.open_path
    # If store resolved to foreign collision alternate, still fine
    if open_path == root / LEGACY_OPEN and not is_owned_open_file(open_path):
        open_path = root / DATA_DIR / OPEN_NAME
        print(
            f"note: root {LEGACY_OPEN} looks like product content — using {open_path}",
            file=sys.stderr,
        )

    if open_path.exists() and open_path.stat().st_size > 0 and not args.force_log:
        if is_owned_open_file(open_path):
            print(f"open log exists {open_path}")
        else:
            print(
                f"error: refusing to write open log at {open_path} (not owned)",
                file=sys.stderr,
            )
            return 1
    else:
        if open_path.exists() and not is_owned_open_file(open_path) and args.force_log:
            print(
                f"error: refusing --force-log on foreign file {open_path}",
                file=sys.stderr,
            )
            return 1
        open_path.parent.mkdir(parents=True, exist_ok=True)
        open_path.write_text(HEADER, encoding="utf-8")
        print(f"created {open_path}")

    hist = store.history_path
    # Prefer history next to open log under .agent-papercuts
    if open_path.parent.name == DATA_DIR:
        hist = open_path.parent / HISTORY_NAME
    hist.parent.mkdir(parents=True, exist_ok=True)
    if not hist.exists():
        hist.write_text("", encoding="utf-8")
        print(f"created {hist} (shadow ledger)")
    else:
        print(f"history exists {hist}")

    # Sidecar readme so humans browsing the folder know it's tooling
    readme = open_path.parent / "README.md"
    if open_path.parent.name == DATA_DIR and not readme.exists():
        readme.write_text(
            "# `.agent-papercuts/`\n\n"
            "Agent-tooling data for the [papercuts](https://github.com/TheMikeFactoryMustGrow/papercuts) "
            "package (coding-agent friction log). **Not product source.**\n\n"
            f"- Open list: `{OPEN_NAME}`\n"
            f"- History: `{HISTORY_NAME}`\n"
            f"- Ownership marker: `{OWNED_MARKER}`\n",
            encoding="utf-8",
        )
        print(f"created {readme}")

    print(
        "\nNext: agents log mid-work; sand with \"fix the papercuts\"; "
        "quarterly \"papercuts kaizen\"."
    )
    return 0


def _snippet_status(root: Path) -> tuple[str, Path | None]:
    heading = re.compile(
        r"^##\s+Log (agent )?papercuts\b", re.MULTILINE | re.IGNORECASE
    )
    for name in ("AGENTS.md", "CLAUDE.md", "agents.md", "CLAUDE.local.md"):
        p = root / name
        if not p.exists():
            continue
        text = p.read_text(encoding="utf-8", errors="replace")
        if _snippet_markers_present(text):
            return "present", p
        if heading.search(text):
            return "present", p
        if re.search(r"\bpapercut\b", text, re.IGNORECASE) and (
            DATA_DIR in text or "PAPERCUTS.md" in text or "agent-papercuts" in text
        ):
            return "partial", p
    return "missing", root / "AGENTS.md"


def cmd_status(args: argparse.Namespace) -> int:
    start = Path(args.cwd) if args.cwd else Path.cwd()
    root = find_repo_root(start)
    store = resolve_store(root)
    snippet_state, snippet_path = _snippet_status(root)

    entry_count = 0
    log_state = "missing"
    owned = False
    if store.open_path.exists():
        owned = is_owned_open_file(store.open_path)
        if owned:
            entries = parse_entries(
                store.open_path.read_text(encoding="utf-8", errors="replace")
            )
            entry_count = len(entries)
            log_state = "empty" if entry_count == 0 else "has_entries"
        else:
            log_state = "foreign"

    hist_events = read_history(store.history_path)
    hist_state = "missing"
    if store.history_path.exists():
        hist_state = "empty" if not hist_events else "has_events"

    foreign_root = root / LEGACY_OPEN
    foreign = foreign_root.exists() and not is_owned_open_file(foreign_root)

    cli = shutil.which("agent-papercut") or shutil.which("papercut")
    skill_hits = []
    home = Path.home()
    for skill_name in ("papercuts", "papercuts-kaizen"):
        for base in (
            home / ".claude" / "skills",
            home / ".grok" / "skills",
            home / ".agents" / "skills",
        ):
            p = base / skill_name / "SKILL.md"
            if p.exists():
                skill_hits.append(str(p))

    print(f"repo_root={root}")
    print(f"git={str((root / '.git').exists()).lower()}")
    print(f"data_dir={root / DATA_DIR}")
    print(f"owned_marker={OWNED_MARKER}")
    print(f"snippet={snippet_state}")
    print(f"snippet_path={snippet_path}")
    print(f"log={log_state}")
    print(f"log_owned={str(owned).lower()}")
    print(f"log_path={store.open_path}")
    print(f"log_entries={entry_count}")
    print(f"history={hist_state}")
    print(f"history_path={store.history_path}")
    print(f"history_events={len(hist_events)}")
    print(f"foreign_root_PAPERCUTS_md={str(foreign).lower()}")
    if foreign:
        print(f"foreign_path={foreign_root}")
    for w in store.warnings:
        print(f"warning={w}")
    print(f"cli_on_path={str(bool(cli)).lower()}")
    print(f"cli_path={cli or ''}")
    print(
        f"skill_installed={str(any(s.endswith('papercuts/SKILL.md') for s in skill_hits)).lower()}"
    )
    for s in skill_hits:
        print(f"skill_path={s}")

    needs_enable = snippet_state != "present" or log_state in ("missing", "foreign")
    # foreign open path without owned log => need enable into safe dir
    if log_state == "foreign":
        needs_enable = True
    print(f"project_enabled={str(not needs_enable and log_state != 'foreign').lower()}")
    print(f"needs_enable={str(needs_enable).lower()}")

    if needs_enable:
        print(
            "\nProject is not fully enabled for agent-papercuts capture.\n"
            "  Ask the user, then run:  papercut enable\n"
            f"  Data goes under {DATA_DIR}/ (won’t touch foreign {LEGACY_OPEN}).",
            file=sys.stderr,
        )
        return 1
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="papercut",
        description="Agent friction log (collision-safe .agent-papercuts/ data).",
    )
    p.add_argument("-C", "--cwd", default=None, help="start directory for repo discovery")
    sub = p.add_subparsers(dest="command")

    log_p = sub.add_parser("log", help="append an open-list entry + history")
    log_p.add_argument("-m", "--model", default=None)
    log_p.add_argument("-a", "--author", default=None)
    log_p.add_argument("message", nargs="+")

    list_p = sub.add_parser("list", help="list open entries (newest first)")
    list_p.add_argument("-n", type=int, default=None)

    res = sub.add_parser("resolve", help="clear open entries after a fix; append history")
    res.add_argument("-n", "--note", required=True, help="one-line preventive fix")
    res.add_argument("--stamp", action="append", default=None)
    res.add_argument("--contains", default=None)
    res.add_argument("--index", type=int, action="append", default=None)

    hist = sub.add_parser("history", help="read shadow ledger")
    hist.add_argument("-n", type=int, default=None)
    hist.add_argument("--event", choices=("logged", "resolved"), default=None)
    hist.add_argument("--stats", action="store_true")

    sub.add_parser("path", help="print path to open log")
    init_p = sub.add_parser("init", help="create owned open log")
    init_p.add_argument("-f", "--force", action="store_true")

    inst = sub.add_parser("install", help="install skills + CLI")
    inst.add_argument("--claude", action="store_true")
    inst.add_argument("--grok", action="store_true")
    inst.add_argument("--agents", action="store_true")

    en = sub.add_parser("enable", help="enable in current git repo (safe data dir)")
    en.add_argument("-f", "--force", action="store_true")
    en.add_argument("--force-log", action="store_true")
    en.add_argument("--prefer-claude", action="store_true")

    sub.add_parser("status", help="setup + ownership + collision warnings")

    p.add_argument("-m", "--model", default=None, help=argparse.SUPPRESS)
    p.add_argument("-a", "--author", default=None, help=argparse.SUPPRESS)
    p.add_argument("bare_message", nargs="*", help=argparse.SUPPRESS)
    return p


def inject_default_log(argv: list[str]) -> list[str]:
    i = 0
    while i < len(argv):
        tok = argv[i]
        if tok in ("-h", "--help"):
            return argv
        if tok in SUBCOMMANDS:
            return argv
        if tok in ("-C", "--cwd"):
            i += 2
            continue
        if tok.startswith("-"):
            return ["log", *argv]
        return ["log", *argv]
    return argv


def main(argv: list[str] | None = None) -> int:
    argv = inject_default_log(list(sys.argv[1:] if argv is None else argv))
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.command is None:
        if getattr(args, "bare_message", None):
            args.command = "log"
            args.message = args.bare_message
        else:
            parser.print_help()
            return 2

    dispatch = {
        "log": cmd_log,
        "list": cmd_list,
        "path": cmd_path,
        "init": cmd_init,
        "install": cmd_install,
        "enable": cmd_enable,
        "status": cmd_status,
        "resolve": cmd_resolve,
        "history": cmd_history,
    }
    fn = dispatch.get(args.command)
    if not fn:
        parser.print_help()
        return 2
    return fn(args)


if __name__ == "__main__":
    sys.exit(main())
